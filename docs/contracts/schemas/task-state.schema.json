{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "workflow_id",
    "contract_version",
    "change_type",
    "risk_level",
    "state",
    "rework_count",
    "max_rework_attempts",
    "history",
    "evidence",
    "next_route",
    "stop_reason"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "workflow_id": { "type": "string", "minLength": 1 },
    "contract_version": { "type": "integer", "minimum": 1 },
    "change_type": { "enum": ["bug-fix"] },
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "state": { "enum": ["intake", "investigating", "implementing", "verifying", "rework", "handoff", "blocked"] },
    "rework_count": { "type": "integer", "minimum": 0 },
    "max_rework_attempts": { "type": "integer", "minimum": 0 },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "at", "actor", "evidence_refs"],
        "properties": {
          "from": { "enum": ["intake", "investigating", "implementing", "verifying", "rework", "handoff", "blocked"] },
          "to": { "enum": ["intake", "investigating", "implementing", "verifying", "rework", "handoff", "blocked"] },
          "at": { "type": "string", "minLength": 1 },
          "actor": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "evidence": { "type": "object" },
    "next_route": { "type": "string", "minLength": 1 },
    "stop_reason": { "type": ["string", "null"] }
  }
}
